#: pretix_paykeeper/apps.py:15
msgid "Paykeeper payment provider plugin for pretix"
msgstr "Платежный провайдер Paykeeper для pretix"

#: pretix_paykeeper/payment.py:34
msgid "Paykeeper Server URL"
msgstr "Ссылка на сервер Paykeeper"

#: pretix_paykeeper/payment.py:35
msgid "Full URL of your Paykeeper server, e.g."
